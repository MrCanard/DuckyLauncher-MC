{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DuckyLauncher",
  "version": "0.1.0",
  "identifier": "com.example.duckyluncher",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "DuckyLauncher",
        "width": 1150,
        "height": 740,
        "minWidth": 850,
        "minHeight": 580
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["French", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
